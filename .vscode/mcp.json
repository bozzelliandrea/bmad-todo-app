{
  "servers": {
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres@0.6.2",
        "${input:pg_url}"
      ],
      "inputs": [
        {
          "id": "pg_url",
          "type": "promptString",
          "description": "PostgreSQL connection URL",
          "default": "postgresql://todo_user:todo_password@localhost:5432/todo_db"
        }
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@0.0.68",
        "--headless"
      ]
    }
  }
}
